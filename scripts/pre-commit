#!/usr/bin/env bash
# Pre-commit hook: runs treefmt, go vet, golangci-lint, and gosec on staged files.
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
#   — or — ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

set -euo pipefail

# Only check staged added/copied/modified files.
STAGED=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -z "$STAGED" ]; then
  exit 0
fi

FORMATTABLE=$(printf '%s\n' "$STAGED" | grep -E '(\.go|\.css|\.html|\.js|\.json|\.md|\.svelte|\.toml|\.ts|\.yaml|\.yml|\.sh)$|^scripts/pre-commit$' || true)
GO_STAGED=$(printf '%s\n' "$STAGED" | grep '\.go$' || true)

echo "pre-commit: checking $(printf '%s\n' "$STAGED" | wc -l | tr -d ' ') staged files..."

# 1. treefmt — check only, no auto-rewrite (fail if unformatted).
if [ -n "$FORMATTABLE" ]; then
  echo "pre-commit: treefmt..."
  if ! treefmt --no-cache --fail-on-change --on-unmatched=debug $FORMATTABLE 2>&1; then
    echo "ERROR: treefmt found unformatted staged files"
    echo ""
    echo "Run: treefmt \$(git diff --cached --name-only --diff-filter=ACM)"
    exit 1
  fi
fi

if [ -z "$GO_STAGED" ]; then
  echo "pre-commit: formatting checks passed"
  exit 0
fi

# Collect the packages that contain staged Go files.
PACKAGES=$(printf '%s\n' "$GO_STAGED" | xargs -I{} dirname {} | sort -u | sed 's|^|./|')

# 2. go vet — run on affected packages.
echo "pre-commit: go vet..."
if ! go vet $PACKAGES 2>&1; then
  echo "ERROR: go vet failed"
  exit 1
fi

# 3. golangci-lint — run via the canonical repo wrapper.
echo "pre-commit: golangci-lint..."
if ! ./scripts/lint.sh $PACKAGES 2>&1; then
  echo "ERROR: golangci-lint failed"
  exit 1
fi

# 4. gosec — security scanner on affected packages.
if command -v gosec &>/dev/null; then
  GOSEC=gosec
elif [ -x "$HOME/go/bin/gosec" ]; then
  GOSEC="$HOME/go/bin/gosec"
else
  echo "pre-commit: gosec not found, skipping security check"
  echo "  Install: go install github.com/securego/gosec/v2/cmd/gosec@latest"
  echo "pre-commit: all other checks passed"
  exit 0
fi

echo "pre-commit: gosec..."
if ! $GOSEC -quiet $PACKAGES 2>&1; then
  echo "ERROR: gosec found security issues"
  exit 1
fi

echo "pre-commit: all checks passed"
